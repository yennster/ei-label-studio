# Interactive segmentation (SAM / OpenMMLab label_anything) — see ml-backend/.
# These power the "Image · Segment Anything (SAM)" template (Point2Label / Bbox2Label).

# /predict endpoint of the hosted MobileSAM backend (a Hugging Face Docker Space).
# Leave unset to fall back to a local backend at http://localhost:8003/predict.
SAM_BACKEND_URL=https://<you>-<space-name>.hf.space/predict

# Optional: Authorization header value sent to the backend, for a *private* HF Space.
# SAM_BACKEND_AUTH=Bearer hf_xxxxxxxxxxxxxxxxxxxxx

# Vercel Blob token — used to hand the backend a temporary public URL for each image.
# Auto-injected on Vercel once a Blob store is linked to the project; for local dev
# against a remote backend, pull it with `vercel env pull`. When unset, the predict
# route falls back to writing public/tmp (only works with a fully-local backend).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxx
