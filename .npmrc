# pnpm 11 treats a dependency that skips its build script as a fatal install
# error by default (ERR_PNPM_IGNORED_BUILDS). The build allow-list lives in
# pnpm-workspace.yaml (onlyBuiltDependencies); anything outside it (e.g. the
# transitive `msw` pulled in by the test tooling) should be a warning, not a
# hard failure that breaks `pnpm install` and CI's `--frozen-lockfile`.
strict-dep-builds=false
